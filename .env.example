# ── Telegram ──────────────────────────────────────────────────────────────────
# Required: get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of your Ollama instance (default shown below)
OLLAMA_HOST=http://localhost:11434

# Model used by the routing/tooling agent — needs reliable tool-call support
# Recommended: llama3.1:8b or any model with function-calling support
OLLAMA_TOOLING_MODEL=llama3.1:8b

# Model used by the chat/summarising agent — can be lighter/faster
# Recommended: llama3.2:3b or any conversational model
OLLAMA_CHAT_MODEL=llama3.2:3b
